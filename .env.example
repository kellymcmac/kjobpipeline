# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored, so your secrets never get committed.
# These four values are the ONLY things you need to provide.

# Your Airtable personal access token (starts with "pat...").
# Create one at https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Airtable base ID (starts with "app...").
# Open your base in a browser; it's the "app..." part of the URL.
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# The Gmail address that receives your LinkedIn / Indeed job-alert emails.
GMAIL_ADDRESS=you@gmail.com

# A Gmail "App Password" (16 characters, no spaces).
# Create one at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
